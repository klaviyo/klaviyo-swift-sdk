            "content": "//\n//  JWTParserTests.swift\n//  klaviyo-swift-sdk\n//\n//  Created by Andrew Balmer on 2026-05-14.\n//\n\n@testable import KlaviyoCore\nimport XCTest\n\nfinal class JWTParserTests: XCTestCase {\n    private static let referenceNow = Date(timeIntervalSince1970: 1_700_000_000)\n    private static let defaultIat: TimeInterval = 1_700_000_000 - 60\n    private static let defaultExp: TimeInterval = 1_700_000_000 + 3600\n\n    // MARK: - Happy path\n\n    func testValidToken_returnsValidatedTokenWithDecodedClaims() throws {\n        let token = try makeJWT()\n\n        let validated = try unwrap(JWTParser.parseAndValidate(token, now: Self.referenceNow))\n\n        XCTAssertEqual(validated.rawToken, token)\n        XCTAssertEqual(validated.issuedAt, Date(timeIntervalSince1970: Self.defaultIat))\n        XCTAssertEqual(validated.expiresAt, Date(timeIntervalSince1970: Self.defaultExp))\n    }\n\n    func testValidToken_ignoresUnknownClaims() throws {\n        let token = try makeJWT(extraClaims: [\n            \"sub\": \"user-123\",\n            \"aud\": \"klaviyo\",\n            \"iss\": \"https://auth.example.com\",\n            \"custom_field\": [\"nested\": 42]\n        ])\n\n        let validated = try unwrap(JWTParser.parseAndValidate(token, now: Self.referenceNow))\n\n        XCTAssertEqual(validated.issuedAt, Date(timeIntervalSince1970: Self.defaultIat))\n        XCTAssertEqual(validated.expiresAt, Date(timeIntervalSince1970: Self.defaultExp))\n    }\n\n    func testValidToken_decodesFractionalNumericDates() throws {\n        let iat = 1_700_000_000.25\n        let exp = 1_700_003_600.75\n        let token = try makeJWT(iat: iat, exp: exp)\n\n        let validated = try unwrap(JWTParser.parseAndValidate(token, now: Self.referenceNow))\n\n        XCTAssertEqual(validated.issuedAt, Date(timeIntervalSince1970: iat))\n        XCTAssertEqual(validated.expiresAt, Date(timeIntervalSince1970: exp))\n    }\n\n    // MARK: - Malformed structure\n\n    func testEmptyString_returnsMalformedStructure() {\n        assertFailure(JWTParser.parseAndValidate(\"\", now: Self.referenceNow), .malformedStructure)\n    }\n\n    func testSingleSegment_returnsMalformedStructure() {\n        assertFailure(JWTParser.parseAndValidate(\"only-one-segment\", now: Self.referenceNow), .malformedStructure)\n    }\n\n    func testTwoSegments_returnsMalformedStructure() {\n        assertFailure(JWTParser.parseAndValidate(\"header.payload\", now: Self.referenceNow), .malformedStructure)\n    }\n\n    func testFourSegments_returnsMalformedStructure() {\n        assertFailure(\n            JWTParser.parseAndValidate(\"a.b.c.d\", now: Self.referenceNow),\n            .malformedStructure\n        )\n    }\n\n    // MARK: - Malformed Base64URL\n\n    func testInvalidBase64Payload_returnsMalformedBase64() throws {\n        let header = try base64URLEncode(JSONSerialization.data(withJSONObject: [\"alg\": \"HS256\"]))\n        // `*` is not a valid base64URL character.\n        let token = \"\\(header).****.signature\"\n\n        assertFailure(\n            JWTParser.parseAndValidate(token, now: Self.referenceNow),\n            .malformedBase64\n        )\n    }\n\n    // MARK: - Malformed JSON\n\n    func testNonJSONPayload_returnsMalformedJSON() throws {\n        let header = try base64URLEncode(JSONSerialization.data(withJSONObject: [\"alg\": \"HS256\"]))\n        let payload = base64URLEncodeString(\"not-actually-json\")\n        let token = \"\\(header).\\(payload).signature\"\n\n        assertFailure(\n            JWTParser.parseAndValidate(token, now: Self.referenceNow),\n            .malformedJSON\n        )\n    }\n\n    func testJSONArrayPayload_returnsMalformedJSON() throws {\n        let header = try base64URLEncode(JSONSerialization.data(withJSONObject: [\"alg\": \"HS256\"]))\n        let payload = try base64URLEncode(JSONSerialization.data(withJSONObject: [1, 2, 3]))\n        let token = \"\\(header).\\(payload).signature\"\n\n        assertFailure(\n            JWTParser.parseAndValidate(token, now: Self.referenceNow),\n            .malformedJSON\n        )\n    }\n\n    func testExpAsString_returnsMalformedJSON() throws {\n        let token = try makeJWT(payload: [\n            \"iat\": Self.defaultIat,\n            \"exp\": \"not-a-number\"\n        ])\n\n        assertFailure(\n            JWTParser.parseAndValidate(token, now: Self.referenceNow),\n            .malformedJSON\n        )\n    }\n\n    // MARK: - Missing claims\n\n    func testMissingExpClaim_returnsMissingExpClaim() throws {\n        let token = try makeJWT(payload: [\"iat\": Self.defaultIat])\n\n        assertFailure(\n            JWTParser.parseAndValidate(token, now: Self.referenceNow),\n            .missingExpClaim\n        )\n    }\n\n    func testMissingIatClaim_returnsMissingIatClaim() throws {\n        let token = try makeJWT(payload: [\"exp\": Self.defaultExp])\n\n        assertFailure(\n            JWTParser.parseAndValidate(token, now: Self.referenceNow),\n            .missingIatClaim\n        )\n    }\n\n    func testEmptyPayload_returnsMissingExpClaim() throws {\n        let token = try makeJWT(payload: [:])\n\n        assertFailure(\n            JWTParser.parseAndValidate(token, now: Self.referenceNow),\n            .missingExpClaim\n        )\n    }\n\n    // MARK: - Expiration\n\n    func testNowEqualsExp_returnsExpiredOnReceipt() throws {\n        let token = try makeJWT()\n\n        assertFailure(\n            JWTParser.parseAndValidate(\n                token,\n                now: Date(timeIntervalSince1970: Self.defaultExp)\n            ),\n            .expiredOnReceipt\n        )\n    }\n\n    func testNowPastExp_returnsExpiredOnReceipt() throws {\n        let token = try makeJWT()\n\n        assertFailure(\n            JWTParser.parseAndValidate(\n                token,\n                now: Date(timeIntervalSince1970: Self.defaultExp + 1)\n            ),\n            .expiredOnReceipt\n        )\n    }\n\n    func testNowAtLeewayBoundary_returnsExpiredOnReceipt() throws {\n        // `now == exp - leeway` is treated as expired (>= rule).\n        let token = try makeJWT()\n        let leeway: TimeInterval = 15\n        let now = Date(timeIntervalSince1970: Self.defaultExp - leeway)\n\n        assertFailure(\n            JWTParser.parseAndValidate(token, now: now, leeway: leeway),\n            .expiredOnReceipt\n        )\n    }\n\n    func testNowJustInsideLeeway_returnsSuccess() throws {\n        // `now == exp - leeway - epsilon` is still valid.\n        let token = try makeJWT()\n        let leeway: TimeInterval = 15\n        let now = Date(timeIntervalSince1970: Self.defaultExp - leeway - 0.001)\n\n        let validated = try unwrap(JWTParser.parseAndValidate(token, now: now, leeway: leeway))\n        XCTAssertEqual(validated.rawToken, token)\n    }\n\n    func testZeroLeeway_movesExpiryBoundaryToExp() throws {\n        let token = try makeJWT()\n\n        // With leeway = 0, `now == exp - 1` is still valid.\n        let justBefore = Date(timeIntervalSince1970: Self.defaultExp - 1)\n        XCTAssertNoThrow(\n            try unwrap(JWTParser.parseAndValidate(token, now: justBefore, leeway: 0))\n        )\n\n        // ...but `now == exp` is expired.\n        assertFailure(\n            JWTParser.parseAndValidate(\n                token,\n                now: Date(timeIntervalSince1970: Self.defaultExp),\n                leeway: 0\n            ),\n            .expiredOnReceipt\n        )\n    }\n\n    func testDefaultLeewayIs15Seconds() {\n        XCTAssertEqual(JWTParser.defaultLeeway, 15)\n    }\n\n    // MARK: - Base64URL handling\n\n    func testPayloadWithUrlSafeCharactersDecodesCorrectly() throws {\n        // Force the payload's base64 encoding to use `-` and `_` substitutions by\n        // choosing claim values that produce those bytes when JSON-encoded.\n        //\n        // Standard base64 emits `+` and `/` for byte sequences containing these bits;\n        // the parser must accept the URL-safe substitutions.\n        let token = try makeJWT(extraClaims: [\"data\": \">>>>???\"])\n\n        let validated = try unwrap(JWTParser.parseAndValidate(token, now: Self.referenceNow))\n        XCTAssertEqual(validated.expiresAt, Date(timeIntervalSince1970: Self.defaultExp))\n    }\n\n    func testPayloadWithoutPaddingDecodesCorrectly() throws {\n        // makeJWT() always strips `=` padding (RFC 7515 §2). This test exists to make\n        // the no-padding case an explicit assertion on the parser's input contract.\n        let token = try makeJWT()\n        XCTAssertFalse(token.contains(\"=\"), \"JWT segments should not contain `=` padding\")\n\n        XCTAssertNoThrow(\n            try unwrap(JWTParser.parseAndValidate(token, now: Self.referenceNow))\n        )\n    }\n\n    // MARK: - Reason strings (logging surface)\n\n    func testValidationFailureReasons_doNotContainTokenAdjacentText() {\n        // The reason strings are passed to the logger with `.public` privacy, so they\n        // must not vary by token contents. This test pins them in case a future change\n        // tries to interpolate token-derived data into them.\n        XCTAssertEqual(JWTValidationFailure.malformedStructure.reason, \"malformed structure\")\n        XCTAssertEqual(JWTValidationFailure.malformedBase64.reason, \"malformed base64URL payload\")\n        XCTAssertEqual(JWTValidationFailure.malformedJSON.reason, \"malformed JSON payload\")\n        XCTAssertEqual(JWTValidationFailure.missingExpClaim.reason, \"missing exp claim\")\n        XCTAssertEqual(JWTValidationFailure.missingIatClaim.reason, \"missing iat claim\")\n        XCTAssertEqual(JWTValidationFailure.expiredOnReceipt.reason, \"expired on receipt\")\n    }\n\n    // MARK: - Helpers\n\n    private func unwrap<Success, Failure>(\n        _ result: Result<Success, Failure>,\n        file: StaticString = #file,\n        line: UInt = #line\n    ) throws -> Success {\n        switch result {\n        case let .success(value):\n            return value\n        case let .failure(error):\n            XCTFail(\"Expected success, got failure: \\(error)\", file: file, line: line)\n            throw error\n        }\n    }\n\n    private func assertFailure(\n        _ result: Result<ValidatedToken, JWTValidationFailure>,\n        _ expected: JWTValidationFailure,\n        file: StaticString = #file,\n        line: UInt = #line\n    ) {\n        switch result {\n        case let .success(value):\n            XCTFail(\"Expected failure \\(expected), got success: \\(value)\", file: file, line: line)\n        case let .failure(actual):\n            XCTAssertEqual(actual, expected, file: file, line: line)\n        }\n    }\n}\n\n// MARK: - JWT Fixture Helpers\n\nprivate extension JWTParserTests {\n    /// Builds a JWT with default `iat`/`exp` and optional extra claims.\n    func makeJWT(\n        iat: TimeInterval? = JWTParserTests.defaultIat,\n        exp: TimeInterval? = JWTParserTests.defaultExp,\n        extraClaims: [String: Any] = [:]\n    ) throws -> String {\n        var payload: [String: Any] = extraClaims\n        if let iat = iat { payload[\"iat\"] = iat }\n        if let exp = exp { payload[\"exp\"] = exp }\n        return try makeJWT(payload: payload)\n    }\n\n    /// Builds a JWT with a caller-specified payload. The header is fixed and the\n    /// signature segment is a placeholder — neither is validated by the parser.\n    func makeJWT(payload: [String: Any]) throws -> String {\n        let header: [String: Any] = [\"alg\": \"HS256\", \"typ\": \"JWT\"]\n        let headerSeg = try base64URLEncode(JSONSerialization.data(withJSONObject: header))\n        let payloadSeg = try base64URLEncode(JSONSerialization.data(withJSONObject: payload))\n        return \"\\(headerSeg).\\(payloadSeg).signature\"\n    }\n\n    func base64URLEncode(_ data: Data) -> String {\n        data.base64EncodedString()\n            .replacingOccurrences(of: \"+\", with: \"-\")\n            .replacingOccurrences(of: \"/\", with: \"_\")\n            .replacingOccurrences(of: \"=\", with: \"\")\n    }\n\n    func base64URLEncodeString(_ string: String) -> String {\n        base64URLEncode(Data(string.utf8))\n    }\n}\n",
